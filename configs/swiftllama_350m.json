{
  "comment": "SwiftLlama-350M — 345M params, trained on FineWeb-Edu (15B tokens target, Muon optimizer)",
  "arch_family": "swiftllama",
  "vocab_size": 50304,
  "d_model": 1024,
  "n_layers": 22,
  "n_heads": 16,
  "num_kv_heads": 4,
  "d_ff": 2730,
  "block_size": 4096,
  "norm_type": "rmsnorm",
  "mlp_type": "swiglu",
  "attention_type": "gqa",
  "pos_encoding_type": "rope",
  "rope_fraction": 0.5,
  "n_value_embeds": 2,
  "use_x0_mixin": true,
  "qk_norm": true,
  "logit_softcap": 30.0,
  "dropout": 0.0,

  "training": {
    "optimizer": "muon_adam",
    "batch_size": 2,
    "grad_accum": 64,
    "block_size": 4096,
    "max_steps": 28610,
    "muon_lr": 0.02,
    "adam_lr": 6e-4,
    "embed_lr": 0.3,
    "unembed_lr": 0.004,
    "scalar_lr": 0.5,
    "weight_decay": 0.1,
    "warmup_steps": 500,
    "lr_schedule": "cosine",
    "grad_clip": 1.0,
    "tokens": "15B"
  }
}
